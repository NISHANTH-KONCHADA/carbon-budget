# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/carbon-footprint

# JWT
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Frontend URL(s) allowed to call this API (comma-separated for multiple)
CLIENT_URL=http://localhost:5173

# Optional — if unset, AI insights fall back to rule-based messages automatically
GROQ_API_KEY=your_groq_api_key_here
